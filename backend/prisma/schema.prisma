generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  avatar      String?
  isAdmin     Boolean  @default(false)
  totpSecret  String?
  totpEnabled Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceMembers      WorkspaceMember[]
  assignedConversations Conversation[]    @relation("AssignedTo")
  reactions             MessageReaction[]
}

model Workspace {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  description          String?
  avatar               String?
  timezone             String    @default("UTC")
  plan                 String    @default("free")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planExpiresAt        DateTime?
  aiEnabled            Boolean   @default(false)
  aiPrompt             String?
  slaHours             Int       @default(24)
  businessHours        String?   // JSON: [{day:0,start:"09:00",end:"18:00",enabled:true}]
  oooEnabled           Boolean   @default(false)
  oooMessage           String?
  onboardingStep       Int       @default(0)
  onboardingCompleted  Boolean   @default(false)
  // White-label
  brandingName         String?
  brandingLogo         String?
  brandingColor        String?
  // Usage tracking
  messageCount         Int       @default(0)
  contactCount         Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  members              WorkspaceMember[]
  channels             Channel[]
  contacts             Contact[]
  conversations        Conversation[]
  tags                 Tag[]
  broadcasts           Broadcast[]
  savedResponses       SavedResponse[]
  customFields         CustomField[]
  outboundWebhooks     OutboundWebhook[]
  templates            WhatsAppTemplate[]
  inboxViews           InboxView[]
  autoAssignRules      AutoAssignRule[]
  apiKeys              ApiKey[]
  auditLogs            AuditLog[]
  automationRules      AutomationRule[]
  contactSegments      ContactSegment[]
  knowledgeArticles    KnowledgeArticle[]
  scheduledMessages    ScheduledMessage[]
  shopifyIntegration   ShopifyIntegration?
  notifications        Notification[]
  flowBots             FlowBot[]
  liveChatWidget       LiveChatWidget?
  trainingDocuments    TrainingDocument[]
}

model Broadcast {
  id            String    @id @default(cuid())
  name          String
  message       String
  status        String    @default("draft")
  workspaceId   String
  channelId     String?
  scheduledAt   DateTime?
  sentAt        DateTime?
  totalContacts Int       @default(0)
  sentCount     Int       @default(0)
  failedCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace  Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipients BroadcastRecipient[]
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  contactId   String
  status      String    @default("pending")
  sentAt      DateTime?

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  role        String   @default("agent")
  userId      String
  workspaceId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Channel {
  id                 String   @id @default(cuid())
  name               String
  type               String   @default("whatsapp") // whatsapp | instagram | messenger | telegram | email | widget
  phoneNumber        String?
  phoneNumberId      String?
  wabaId             String?
  accessToken        String?
  webhookVerifyToken String?
  // Instagram / Messenger fields
  pageId             String?  // Facebook Page ID
  pageAccessToken    String?  // Page Access Token (long-lived)
  instagramAccountId String?  // Instagram Business Account ID
  // Telegram fields
  telegramBotToken   String?
  telegramBotUsername String?
  // Email channel fields
  emailConfig        String?  // JSON: {smtpHost, smtpPort, smtpUser, smtpPass, smtpFrom, imapHost, imapPort, imapUser, imapPass}
  emailAddress       String?
  // Routing
  languages          String?  // JSON array of language codes this channel handles, e.g. ["en","es"]
  status             String   @default("pending")
  workspaceId        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  templates     WhatsAppTemplate[]
}

model Contact {
  id             String   @id @default(cuid())
  name           String
  phone          String?
  email          String?
  avatar         String?
  company        String?
  notes          String?
  lifecycleStage String?  @default("new_lead")
  language       String?  // detected language code e.g. "en", "es", "fr"
  externalId     String?  // platform-specific ID (PSID for Messenger, Instagram UID, Telegram chatId)
  platform       String?  // whatsapp | instagram | messenger | telegram | widget
  workspaceId    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace           Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations       Conversation[]
  contactTags         ContactTag[]
  broadcastRecipients BroadcastRecipient[]
  activities          ContactActivity[]
  customFieldValues   ContactCustomFieldValue[]
}

model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#6366f1")
  workspaceId String
  createdAt   DateTime @default(now())

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactTags      ContactTag[]
  conversationTags ConversationTag[]

  @@unique([name, workspaceId])
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model ConversationTag {
  conversationId String
  tagId          String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
}

model Conversation {
  id              String    @id @default(cuid())
  status          String    @default("open")
  contactId       String
  channelId       String
  workspaceId     String
  assigneeId      String?
  lastMessageAt   DateTime?
  firstResponseAt DateTime?
  snoozedUntil    DateTime?
  slaDueAt        DateTime?
  csatScore       Int?
  csatSentAt      DateTime?
  unreadCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact          Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel          Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee         User?             @relation("AssignedTo", fields: [assigneeId], references: [id])
  messages         Message[]
  conversationTags ConversationTag[]
  csatResponses    CsatResponse[]
  emailThreads     EmailThread[]
}

model SavedResponse {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ContactActivity {
  id          String   @id @default(cuid())
  type        String
  description String
  contactId   String
  workspaceId String
  metadata    String?
  createdAt   DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model CustomField {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("text") // text, number, date, select
  options     String?  // JSON array for select type
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  values    ContactCustomFieldValue[]

  @@unique([name, workspaceId])
}

model ContactCustomFieldValue {
  id        String @id @default(cuid())
  value     String
  contactId String
  fieldId   String

  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  field   CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, fieldId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  emoji     String
  messageId String
  userId    String
  userName  String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model OutboundWebhook {
  id          String   @id @default(cuid())
  name        String
  url         String
  events      String   // JSON array: ["conversation.created","message.received"]
  active      Boolean  @default(true)
  secret      String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WhatsAppTemplate {
  id          String   @id @default(cuid())
  name        String
  content     String
  language    String   @default("en")
  category    String   @default("MARKETING")
  status      String   @default("draft")
  workspaceId String
  channelId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   Channel?  @relation(fields: [channelId], references: [id])
}

model Message {
  id             String   @id @default(cuid())
  content        String
  type           String   @default("text")
  direction      String
  status         String   @default("sent")
  waMessageId    String?
  mediaUrl       String?
  mediaType      String?
  mediaName      String?
  mediaSize      Int?
  isAiReply      Boolean  @default(false)
  isNote         Boolean  @default(false)
  mentions       String?  // JSON array of user IDs mentioned
  intent         String?  // AI-detected intent label
  qualityScore   Int?     // AI quality score 1-5 for outbound messages
  language       String?  // detected language code
  externalId     String?  // platform message ID (Instagram/Messenger/Telegram)
  conversationId String
  senderId       String?
  senderName     String?
  createdAt      DateTime @default(now())

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reactions    MessageReaction[]
}

model InboxView {
  id          String   @id @default(cuid())
  name        String
  filters     String   // JSON: {status, assigneeId, channelId, tagId}
  workspaceId String
  userId      String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AutoAssignRule {
  id          String   @id @default(cuid())
  name        String
  strategy    String   @default("round_robin") // round_robin, least_loaded
  channelId   String?
  tagId       String?
  active      Boolean  @default(true)
  workspaceId String
  assigneeIds String   // JSON array of user IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String    // first 8 chars for display
  workspaceId String
  userId      String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g. "conversation.resolved", "contact.updated"
  entityType  String
  entityId    String
  userId      String
  userName    String
  metadata    String?  // JSON
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CsatResponse {
  id             String   @id @default(cuid())
  score          Int      // 1-5
  comment        String?
  conversationId String
  contactId      String
  workspaceId    String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AutomationRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  trigger     String   // JSON: {event, conditions:[{field,operator,value}]}
  actions     String   // JSON: [{type, ...params}]
  active      Boolean  @default(true)
  runCount    Int      @default(0)
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ContactSegment {
  id          String   @id @default(cuid())
  name        String
  description String?
  filters     String   // JSON: [{field, operator, value}]
  color       String   @default("#6366f1")
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model EmailThread {
  id             String   @id @default(cuid())
  messageId      String   // Email Message-ID header
  conversationId String
  workspaceId    String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([messageId, workspaceId])
}

model Mention {
  id             String   @id @default(cuid())
  messageId      String
  userId         String
  userName       String
  conversationId String
  workspaceId    String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model KnowledgeArticle {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  category    String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ScheduledMessage {
  id             String    @id @default(cuid())
  content        String
  type           String    @default("text")
  conversationId String
  workspaceId    String
  scheduledAt    DateTime
  sent           Boolean   @default(false)
  sentAt         DateTime?
  createdBy      String
  senderName     String?
  createdAt      DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ShopifyIntegration {
  id          String   @id @default(cuid())
  shopDomain  String
  accessToken String
  enabled     Boolean  @default(true)
  workspaceId String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // new_message | mention | assignment | sla_breach | csat | flow
  title       String
  body        String?
  read        Boolean  @default(false)
  userId      String
  workspaceId String
  entityType  String?  // conversation | contact
  entityId    String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model FlowBot {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(false)
  trigger     String   // JSON: {type:'keyword'|'any_message'|'first_message', keywords:[]}
  nodes       String   @db.Text // JSON: array of flow nodes
  edges       String   @db.Text // JSON: array of edges
  channelId   String?
  workspaceId String
  runCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model LiveChatWidget {
  id             String   @id @default(cuid())
  workspaceId    String   @unique
  channelId      String?
  primaryColor   String   @default("#6366f1")
  greeting       String   @default("Hi! How can we help you today?")
  botName        String   @default("Support")
  position       String   @default("bottom-right")
  enabled        Boolean  @default(true)
  allowedOrigins String?  // JSON array of domains
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model TrainingDocument {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  fileType    String?  // pdf | txt | md | url | manual
  fileUrl     String?
  tokens      Int      @default(0)  // approximate word count
  active      Boolean  @default(true)
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
